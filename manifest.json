{
  "manifest_version": 3,
  "name": "Filtrar ofertas empleospublicos.cl",
  "version": "1.0.4",
  "description": "Filtra empleos en empleospublicos.cl basándose en palabras clave personalizadas y categorías profesionales",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.empleospublicos.cl/*",
    "https://empleospublicos.cl/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Filtrar ofertas empleospublicos.cl"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.empleospublicos.cl/*",
        "https://empleospublicos.cl/*"
      ],
      "js": [
        "rubros.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
